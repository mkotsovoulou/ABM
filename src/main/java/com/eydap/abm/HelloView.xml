
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml" fx:controller="com.eydap.abm.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <GridPane hgap="10" vgap="10">
        <Label text="Year:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="yearField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        
        <Label text="Month:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="monthField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        
        <Button text="Run Procedure" onAction="#onRunProcedureClick" 
                GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="2"/>
        
        <Label fx:id="statusLabel" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="3"/>
    </GridPane>
</VBox>
